DATABASE_URL="postgresql://db_user:db_password@db.example.com:5432/app"
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="replace-with-long-random-secret"
ACCESS_TOKEN_TTL_SECONDS="900"
REFRESH_TOKEN_TTL_SECONDS="604800"

REDIS_HOST="redis.example.com"
REDIS_PORT="6379"
REDIS_PASSWORD=""
# Optional: use REDIS_URL instead of host/port/password (ex: redis://:password@host:6379/0)
REDIS_URL=""
REDIS_DB="0"

KAFKA_BROKERS="kafka.example.com:9092"
KAFKA_SASL_MECHANISM="plain"
KAFKA_SECURITY_PROTOCOL="plaintext"
KAFKA_USERNAME=""
KAFKA_PASSWORD=""

# Optional: SSH-based user sync to docker-mailserver automation host
# Use placeholders in commands:
# {{action}} {{id}} {{username}} {{email}} {{name}} {{password}} {{role}}
# Example:
# MAIL_SYNC_SSH_COMMAND_CREATE="kubectl -n mail exec deploy/docker-mailserver -- setup email add {{username}}@example.com {{password}}"
# MAIL_SYNC_SSH_COMMAND_UPDATE="kubectl -n mail exec deploy/docker-mailserver -- setup email update {{username}}@example.com {{password}}"
# MAIL_SYNC_SSH_COMMAND_DELETE="kubectl -n mail exec deploy/docker-mailserver -- setup email del {{username}}@example.com"
MAIL_SYNC_SSH_HOST=""
MAIL_SYNC_SSH_PORT="22"
MAIL_SYNC_SSH_USER=""
MAIL_SYNC_SSH_PASSWORD=""
MAIL_SYNC_SSH_KEY=""
MAIL_SYNC_SSH_TIMEOUT_MS="10000"
MAIL_SYNC_EMAIL_DOMAIN="example.com"
MAIL_SYNC_SSH_COMMAND=""
MAIL_SYNC_SSH_COMMAND_CREATE=""
MAIL_SYNC_SSH_COMMAND_UPDATE=""
MAIL_SYNC_SSH_COMMAND_DELETE=""
MAIL_SYNC_REQUIRED="false"

PROMETHEUS_BASE_URL="https://prometheus.example.com"
PROMETHEUS_AUTH_TOKEN=""
PROMETHEUS_TIMEOUT_MS="4000"
GRAFANA_DASHBOARD_URL="https://grafana.example.com"
