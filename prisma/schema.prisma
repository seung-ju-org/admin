generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
  name         String?
  email        String?  @unique
}

enum Role {
  ADMIN
  USER
}

enum PortfolioLocale {
  EN
  JA
  KO

  @@map("Locale")
}

model PortfolioProject {
  id            String                        @id @db.Uuid
  slug          String                        @unique(map: "Project_slug_key")
  displayOrder  Int                           @map("displayOrder")
  startDate     DateTime                      @map("startDate")
  endDate       DateTime?                     @map("endDate")
  isOngoing     Boolean                       @map("isOngoing")
  links         Json?
  isPublished   Boolean                       @map("isPublished")
  createdAt     DateTime                      @default(now()) @map("createdAt")
  updatedAt     DateTime                      @updatedAt @map("updatedAt")
  deletedAt     DateTime?                     @map("deletedAt")
  translations  PortfolioProjectTranslation[]
  technologies  PortfolioProjectTechnology[]

  @@map("Project")
}

model PortfolioProjectTranslation {
  id           Int             @id
  projectId    String          @map("projectId") @db.Uuid
  locale       PortfolioLocale
  title        String
  company      String?
  role         String
  achievements Json
  createdAt    DateTime        @default(now()) @map("createdAt")
  updatedAt    DateTime        @updatedAt @map("updatedAt")
  project      PortfolioProject @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([projectId, locale], map: "ProjectTranslation_projectId_locale_key")
  @@index([locale], map: "ProjectTranslation_locale_idx")
  @@map("ProjectTranslation")
}

model PortfolioTechnology {
  id           String                     @id @db.Uuid
  name         String                     @unique(map: "Technology_name_key")
  createdAt    DateTime                   @default(now()) @map("createdAt")
  updatedAt    DateTime                   @updatedAt @map("updatedAt")
  projects     PortfolioProjectTechnology[]

  @@map("Technology")
}

model PortfolioProjectTechnology {
  projectId    String            @map("projectId") @db.Uuid
  technologyId String            @map("technologyId") @db.Uuid
  displayOrder Int               @map("displayOrder")
  createdAt    DateTime          @default(now()) @map("createdAt")
  project      PortfolioProject   @relation(fields: [projectId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  technology   PortfolioTechnology @relation(fields: [technologyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([projectId, technologyId])
  @@index([technologyId], map: "ProjectTechnology_technologyId_idx")
  @@map("ProjectTechnology")
}

model PortfolioCareer {
  id           String                       @id @db.Uuid
  company      String
  position     String
  overview     String?
  slug         String
  startDate    DateTime                     @map("startDate")
  endDate      DateTime?                    @map("endDate")
  isOngoing    Boolean                      @default(false) @map("isOngoing")
  displayOrder Int                          @default(0) @map("displayOrder")
  createdAt    DateTime                     @default(now()) @map("createdAt")
  updatedAt    DateTime                     @updatedAt @map("updatedAt")
  translations PortfolioCareerTranslation[]

  @@index([company], map: "Career_company_idx")
  @@index([displayOrder], map: "Career_displayOrder_idx")
  @@index([startDate], map: "Career_startDate_idx")
  @@map("Career")
}

model PortfolioCareerTranslation {
  id          Int             @id
  careerId    String          @map("careerId") @db.Uuid
  locale      PortfolioLocale
  company     String
  position    String
  overview    String?
  createdAt   DateTime        @default(now()) @map("createdAt")
  updatedAt   DateTime        @updatedAt @map("updatedAt")
  career      PortfolioCareer @relation(fields: [careerId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([careerId, locale], map: "CareerTranslation_careerId_locale_key")
  @@index([locale], map: "CareerTranslation_locale_idx")
  @@map("CareerTranslation")
}
